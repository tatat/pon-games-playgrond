# Supply-chain hardening — see docs/toolchain.md § Supply Chain Hygiene.

# Route installs through Takumi Guard (GMO Flatt Security) to block known-malicious
# packages at the registry layer. This anonymous endpoint requires no signup;
# upgrade to https://npm.flatt.tech/ with a Bot ID for tracking / notifications.
registry=https://npm.flatt.tech/

# Refuse to install package versions younger than 3 days
# (filters most smash-and-grab supply-chain attacks; matches Mend Renovate's default).
min-release-age=3

# Disable preinstall / postinstall / prepare lifecycle scripts from dependencies.
# Our own `prepare` (husky) is run explicitly via `npm run prepare` after install.
ignore-scripts=true
